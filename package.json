{
  "name": "dvpi-web",
  "version": "1.0.0",
  "description": "Web-based DVPI calculator",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop dvpi-web",
    "pm2:restart": "pm2 restart dvpi-web"
  },
  "keywords": ["dvpi", "vegetation", "calculator"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "csv-parse": "^5.5.2",
    "axios": "^1.6.2",
    "xml2js": "^0.6.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
